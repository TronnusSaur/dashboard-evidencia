# Configuración del Frontend (Vite)
VITE_FIREBASE_API_KEY=tu-api-key
VITE_FIREBASE_AUTH_DOMAIN=tu-auth-domain.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu-messaging-sender-id
VITE_FIREBASE_APP_ID=tu-app-id
VITE_FIREBASE_MEASUREMENT_ID=tu-measurement-id
VITE_GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com

# Configuración del Micro-servidor y Scripts (Node.js)
PORT=3001
CORS_ORIGIN=http://localhost:5173
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback

# Credenciales de Cuenta de Servicio (JSON como string de una línea)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "...", ...}'

# Opcional: Token de usuario persistente (JSON como string de una línea)
GOOGLE_USER_TOKEN_JSON='{"access_token": "...", "refresh_token": "...", ...}'
